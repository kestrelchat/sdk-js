{
  "name": "@kestrelchat/sdk",
  "version": "0.1.0",
  "description": "SDK For Kestrel Chat API",
  "author": "Kestrel Chat <dev@kestrel.chat>",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/kestrelchat/sdk.git"
  },
  "homepage": "https://github.com/kestrelchat/sdk#readme",
  "bugs": {
    "url": "https://github.com/kestrelchat/sdk/issues"
  },
  "packageManager": "yarn@4.12.0",
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "clean": "rimraf dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
